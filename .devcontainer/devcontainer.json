{
	"name": "Wasp C++ Environment",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"mounts": [
		"source=wasp-ccache,target=/home/vscode/.cache/ccache,type=volume"
	],
	"containerEnv": {
		"CCACHE_DIR": "/home/vscode/.cache/ccache"
	},
	"customizations": {
		"vscode": {
			"settings": {
				// CRITICAL: Disable MS IntelliSense so it doesn't conflict with Clangd
				"C_Cpp.intelliSenseEngine": "disabled",
				"C_Cpp.formatting": "disabled",
				// Tell Clangd exactly how to run for maximum performance
				"clangd.arguments": [
					"--compile-commands-dir=${workspaceFolder}/build",
					"--background-index",
					"--clang-tidy",
					"--header-insertion=iwyu",
					"--completion-style=detailed"
				],
				// Quality of life: Auto-format your C++ code on save
				"editor.formatOnSave": false,
				"[cpp]": {
					"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
				}
			},
			"extensions": [
				"llvm-vs-code-extensions.vscode-clangd",
				"ms-vscode.cmake-tools",
				"vadimcn.vscode-lldb",
				"mrmlnc.vscode-duplicate",
				"codezombiech.gitignore",
				"redhat.vscode-yaml"
			]
		}
	},
	// Automatically generate build files and compile_commands.json right after the container spins up
	"postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.cache/ccache && git config --global user.email 'pranavap96@gmail.com' && git config --global user.name 'pranav-ap' && ccache -M 5G && cmake -B build -G Ninja && cmake --build build && ctest --test-dir build -L \"unit\""
}
