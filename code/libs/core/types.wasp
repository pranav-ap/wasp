import my.io expose *


class Boolean
    value: @bool

    fun repr()
        print(my.value)

type bool = Boolean


class Int
    value: @int

    fun repr()
        print(my.value)


type int = Int

class Float
    value: @float

    fun repr()
        print(my.value)

type float = Float


class String
    value: @str

    fun repr()
        print(my.value)

    fun repr2()
        print(my.value)


type str = String


