import core.io expose *
import core.types expose *
import core.operators expose *


class Foo is Printable
    score: int

    fun repr() => str
        return 'Foo : {self.score}'


let f = Foo(1)
print(f)


fun show() => int
    let x = 1

    let z = x + 2
    return z


let g = show()
print(g)



