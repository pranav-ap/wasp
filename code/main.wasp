import core.io expose *
import core.types expose *
import core.operators expose *


trait Debug
    pure fun repr2() => str
        required

    pure fun repr2(a: int) => str
        pass


trait Player
    fun play()
        required


class Jordan is Debug & Player
    name: str

    pure fun repr2() => str
        return 'name = {my.name}'

    pure fun repr2(a: int) => str
        return 'hi'

    fun play()
        let k = 9
        k.repr()


fun shout(d: Debug)
    let y = d.repr2()
    y.repr()

let j = Jordan('jordan')
shout(j)
