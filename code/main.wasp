from core.io import print


class Int
    value: native int

    fun repr()
        print(my.value)


type int = Int


operator + (left: Int, right: Int) => Int
    return Int(left.value + right.value)


fun print(item: Int)
    print('inside overload')
    print(item.value)


let x: int = 1
print(x)
