class Book
    id: int
    text: str

    fun defaults()
        my.id = -1
        my.text = ''

    fun new(id: int)
        my.id = id
        my.text = 'jane doe'

    fun new(id: int, text: str)
        my.id = id
        my.text = text

    fun trim() => str
        return my.text

    fun trim(a: int) => str
        return my.text



Book.new(1)
Book.new(1, 'sam')

