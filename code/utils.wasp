fun print_header(title: str)
    print('=== ' + title + ' ===')


fun print_header(title: str, border: str)
    print(border + border + border + ' ' + title + ' ' + border + border + border)


class Book
    id: int
    text: str

    our pure fun new(id: int) => Book
        return Book(id, 'jane doe')

    our pure fun new(id: int, text: str) => Book
        return Book(id, text)

    fun trim() => str
        return my.text

    fun trim(a: int) => str
        return my.text

