fun print_header(title: str)
    print('=== ' + title + ' ===')


fun print_header(title: str, border: str)
    print(border + border + border + ' ' + title + ' ' + border + border + border)


class Book
    id: int
    text: str

    fun trim() => str
        return my.text

    fun trim(a: int) => str
        return my.text

