digraph CFG {
    node [shape=box, fontname="Courier", style=filled, fillcolor="#f9f9f9"];

    block0 [label="Block 0\l---------------------------------\l  0: ENTER_MODULE\l  1: JUMP            1\l\l"];
    block1 [label="Block 1\l---------------------------------\l  0: LOAD_TRUE\l  1: JUMP_IF_FALSE   3\l  4: JUMP            2\l\l"];
    block2 [label="Block 2\l---------------------------------\l  0: PUSH_SCOPE\l  1: POP_SCOPE\l  2: JUMP            2\l  5: POP_SCOPE\l  6: JUMP            1\l\l"];
    block3 [label="Block 3\l---------------------------------\l  0: JUMP            4\l\l"];
    block4 [label="Block 4\l---------------------------------\l  0: EXIT_MODULE\l\l"];

    // 2. Output all the Edges
    block0 -> block1;
    block1 -> block2;
    block1 -> block3;
    block2 -> block2;
    block2 -> block1;
    block3 -> block4;
}
