digraph CFG {
    node [shape=box, fontname="Courier", style=filled, fillcolor="#f9f9f9"];

    block0 [label="Block 0\l---------------------------------\l   0: ENTER_MODULE\l   1: LOAD_CONST      10         (1)\l   3: LOAD_CONST      11         (2)\l   5: LOAD_CONST      12         (3)\l   7: BUILD_LIST      3\l   9: JUMP            1\l\l"];
    block1 [label="Block 1\l---------------------------------\l  0: LOOP_ITER       3\l  3: JUMP            2\l\l"];
    block2 [label="Block 2\l---------------------------------\l   0: PUSH_SCOPE\l   1: DEFINE_LOCAL    0         (x)\l   3: GET_LOCAL       0         (x)\l   5: POP\l   6: POP_SCOPE\l   7: JUMP            1\l\l"];
    block3 [label="Block 3\l---------------------------------\l  0: POP\l  1: JUMP            4\l\l"];
    block4 [label="Block 4\l---------------------------------\l  0: EXIT_MODULE\l\l"];

    // 2. Output all the Edges
    block0 -> block1;
    block1 -> block2;
    block1 -> block3;
    block2 -> block1;
    block3 -> block4;
}
