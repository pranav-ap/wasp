digraph CFG {
    node [shape=box, fontname="Courier", style=filled, fillcolor="#f9f9f9"];

    block0 [label="Block 0\l---------------------------------\l  0: ENTER_MODULE\l  1: JUMP            1\l\l"];
    block1 [label="Block 1\l---------------------------------\l  0: LOAD_TRUE\l  1: JUMP_IF_FALSE   3\l  4: JUMP            2\l\l"];
    block2 [label="Block 2\l---------------------------------\l  0: PUSH_SCOPE\l  1: LOAD_TRUE\l  2: JUMP_IF_FALSE   5\l  5: JUMP            4\l\l"];
    block3 [label="Block 3\l---------------------------------\l  0: JUMP            6\l\l"];
    block4 [label="Block 4\l---------------------------------\l   0: PUSH_SCOPE\l   1: POP_SCOPE\l   2: POP_SCOPE\l   3: JUMP            3\l   6: POP_SCOPE\l   7: JUMP            5\l\l"];
    block5 [label="Block 5\l---------------------------------\l  0: POP_SCOPE\l  1: JUMP            1\l\l"];
    block6 [label="Block 6\l---------------------------------\l  0: EXIT_MODULE\l\l"];

    // 2. Output all the Edges
    block0 -> block1;
    block1 -> block2;
    block1 -> block3;
    block2 -> block4;
    block2 -> block5;
    block3 -> block6;
    block4 -> block3;
    block4 -> block5;
    block5 -> block1;
}
