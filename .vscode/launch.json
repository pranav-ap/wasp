{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Wasp",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/wasp",
            "args": [
                "run",
                "${workspaceFolder}/workspace" 
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Unit Tests",
            "type": "lldb",
            "request": "launch",
            // This variables looks at the 'inputs' array at the bottom!
            "program": "${workspaceFolder}/build/tests/${input:testTarget}",
            // TIP: If you only want to debug one specific test, add it here!
            // Example: ["--gtest_filter=CompileFunctions.Print"]
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build",
            "sourceFileMap": {
                "/workspaces/wasp": "${workspaceFolder}"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "inputs": [
        {
            "id": "testTarget",
            "type": "pickString",
            "description": "Which Test Suite do you want to debug?",
            "options": [
                "lexer_tests",
                "parser_tests",
                "semantics_tests",
                "compiler_tests",
            ],
            "default": "compiler_tests"
        }
    ]
}