{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wasp",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/wasp",
      "args": ["run", "./code/main.wasp"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
    },
    {
      "name": "Unit Tests",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/${input:testTarget}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build",
    },
  ],
  "inputs": [
    {
      "id": "testTarget",
      "type": "pickString",
      "description": "Which Test Suite do you want to debug?",
      "options": [
        "lexer_tests",
        "parser_tests",
        "semantics_tests",
        "compiler_tests",
      ],
      "default": "compiler_tests",
    },
  ],
}
