{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Wasp",
            "type": "lldb-dap",
            "request": "launch",
            // POINT TO YOUR LOCAL BINARY
            "lldb-dap": "/usr/bin/lldb-vscode-14",
            "program": "${workspaceFolder}/build/src/wasp",
            "args": [
                "run",
                "./code/main.wasp"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Unit Tests",
            "type": "lldb-dap",
            "request": "launch",
            // POINT TO YOUR LOCAL BINARY
            "lldb-dap": "/usr/bin/lldb-vscode-14",
            "program": "${workspaceFolder}/build/tests/${input:testTarget}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "sourceFileMap": {
                "/workspaces/wasp": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "testTarget",
            "type": "pickString",
            "description": "Which Test Suite do you want to debug?",
            "options": [
                "lexer_tests",
                "parser_tests",
                "semantics_tests",
                "compiler_tests"
            ],
            "default": "compiler_tests"
        }
    ]
}