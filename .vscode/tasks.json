{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": false,
                "clear": true,
                "focus": true
            }
        },
        {
            "label": "Build and Test",
            "type": "shell",
            "command": "cmake --build build && ctest --test-dir build -L \"unit\"",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": false,
                "clear": true,
                "focus": true
            }
        },
        {
            "label": "Run Benchmarks",
            "type": "shell",
            "command": "cmake --build build --target bench_lexer && ./build/benchmarks/bench_lexer",
            "group": "test",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": false,
                "clear": true,
                "focus": true
            }
        },
    ],
}