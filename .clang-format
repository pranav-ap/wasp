BasedOnStyle: LLVM

IndentWidth: 4
TabWidth: 4
UseTab: Never

ColumnLimit: 85

PointerAlignment: Left

# --- Variable Assignment Fixes ---
# High penalty prevents 'auto' from being orphaned on its own line
PenaltyReturnTypeOnItsOwnLine: 1000000
PenaltyBreakAssignment: 5000

# Low penalty encourages breaking inside the ( ) instead of the assignment
PenaltyBreakBeforeFirstCallParameter: 1

BinPackArguments: false
BinPackParameters: false

AccessModifierOffset: -4

AlignAfterOpenBracket: BlockIndent
ContinuationIndentWidth: 4

AlwaysBreakAfterReturnType: None
AlwaysBreakAfterDefinitionReturnType: None

AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false

# --- The Magic for Lambdas & Allman Braces ---

AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: None
AllowShortLambdasOnASingleLine: None

# Forces braces for single-line if/else/for/while/do statements
InsertBraces: true
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false

BreakBeforeBraces: Custom
BraceWrapping:
    AfterClass: true
    AfterControlStatement: Always
    AfterEnum: true
    AfterFunction: true
    AfterNamespace: true
    AfterObjCDeclaration: true
    AfterStruct: true
    AfterUnion: true
    AfterExternBlock: true
    BeforeCatch: true
    BeforeElse: true
    BeforeLambdaBody: true
    BeforeWhile: true
    IndentBraces: false
    SplitEmptyFunction: true
    SplitEmptyRecord: true
    SplitEmptyNamespace: true

SeparateDefinitionBlocks: Always
MaxEmptyLinesToKeep: 1
